@page "/"
@using GameStore.Frontend.Clients
@using GameStore.Frontend.Models
@inject idopontokClient Client
@inject massagesClient mClient
@inject ugyfelekClient uClient
@attribute [StreamRendering]

<PageTitle>Foglalás</PageTitle>

<div class="mt-2">
<a class="btn btn-primary" role="button" href="/editgame">Új időpont</a>
</div>

@if(idopontok is null)
{
    <p><em>Loading...</em></p>
}
else {
    <table class="table table-striped table-bordered table-hover mt-3">
    <thead class="table-dark">
        <th>Id</th>
        <th>massage</th>
        <th>ugyfelek</th>
        <th>idopont</th>
        <th>Actions</th>
    </thead>
    <tbody>
        @foreach (var idopont in idopontok)
        {
            <tr>
                <td>@idopont.Id</td>
                <td>@foreach (var massage in massages)
                    {
                        if (massage.Id == idopont.Id_massage)
                        {
                            @massage.MessageType
                        }
                    }                 
                   
                    </td>
                <td>@foreach (var ugyfel in ugyfelek)
                    {
                        if (ugyfel.Id == idopont.Id_ugyfelek)
                        {
                            @ugyfel.Nev
                        }
                    }                 
                   
                    </td>
                <td>@idopont.MassaageIdopont</td>
                <td>
                    <!--<div class="d-flex">
                        <a class="btn btn-primary me-2" role="button" href="@IdopontUrl(idopont.id)" >
                        <i class="bi bi-pencil"></i>
                        <button class="btn btn-danger" data-bs-toggle="modal" data-bs-target="@GetDeleteModalId(idopont)" ><i class="bi bi-x-lg"></i></button>
                        </a>
                    </div>
                    <DeleteIdopont idopont="@idopont" />-->
                </td>                
            </tr>
        }
    </tbody>
    </table>
}

@code {
    private idopontokSummary[]? idopontok;
    private massagesSummary[]? massages;
    private ugyfelekSummary[]? ugyfelek;

    protected override async Task OnInitializedAsync()
    {
        idopontok = await Client.GetidopontokAsync();
        massages = await mClient.GetmassagesAsync();
        ugyfelek = await uClient.GetugyfelekAsync();
    }

    private static string IdopontUrl(int id) => $"/editgame/{id}";     

   /* private string GetDeleteModalId(idopontokSummary idopont) {
        return $"#{DeleteIdopont.GetModalId(idopont)}";
    } */
}

